{
  "name": "attendance-tracker",
  "version": "1.0.0",
  "description": "Трекер посещаемости по цветам",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "NODE_ENV=development vite",
    "electron:build": "vite build && electron-builder --mac --universal",
    "electron:build:win": "vite build && electron-builder --win"
  },
  "build": {
    "appId": "com.attendance.tracker",
    "productName": "AttendanceTracker",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis"]
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@quasar/extras": "^1.18.0",
    "exceljs": "^4.4.0",
    "quasar": "^2.19.3",
    "vue": "^3.5.33",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@quasar/vite-plugin": "^1.11.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "sass": "^1.99.0",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^0.29.1"
  }
}
